# lib/blockstore.s - BlockStore

.include	"common.inc"
.include	"linux.inc"

.globl	BlockStore_ctor, BlockStore_read, BlockStore_write, BlockStore_place, BlockStore_free

# BlockHead
	.struct	0
BlockStore.fr:
	.struct	BlockStore.fr + 1<<2
BlockStore.sz:
	.struct	BlockStore.sz + 1<<2
.equ	BLOCKSTOREHEAD_SIZE, .
BlockStore.ln:
	.struct	BlockStore.ln + 1<<2
.equ	BLOCKSTOREMETA_SIZE, .
BlockStore.fd:
	.struct	BlockStore.fd + 1<<2
.equ	BLOCKSTORE_SIZE, .

.section .text

# @public	BlockStore_ctor
# @description	Creates a new BlockStore
# @param	%rdi	Filename of backing file
# @param	%rsi	Block size
# @return	%rax	Pointer to a new BlockStore
.equ	FILE, -8
.equ	SIZE, -16
.equ	THIS, -24
.type	BlockStore_ctor, @function
BlockStore_ctor:
	push	%rbp
	mov	%rsp, %rbp

	sub	$24, %rsp
	mov	%rdi, FILE(%rbp)

	# Update the requested size to include space for, and be a multiple of the header size
	add	$(2 * BLOCKSTOREHEAD_SIZE - 1), %rsi
	and	$~(BLOCKSTOREHEAD_SIZE - 1), %rsi
	mov	%rsi, SIZE(%rbp)

	# Allocate memory for the BlockStore struct
	mov	$BLOCKSTORE_SIZE, %rdi
	call	alloc
	mov	%rax, THIS(%rbp)
	
	mov	FILE(%rbp), %rdi
	mov	$(O_CREAT|O_EXCL|O_RDWR), %rsi
	mov	$0644, %rdx
	mov	$SYS_OPEN, %rax
	syscall

	cmp	$EEXIST, %al
	je	1f

	# Backing file does not exist. Initialize default header and write it to file
	mov	THIS(%rbp), %rdi
	movl	$0, BlockStore.fr(%rdi)		# Free
	movl	$0, BlockStore.ln(%rdi)		# Length
	mov	%eax, BlockStore.fd(%rdi)	# File descriptor
	mov	SIZE(%rbp), %rax
	mov	%eax, BlockStore.sz(%rdi)	# BLock size

	# Write the new head information to disk
	mov	%rdi, %rsi
	mov	$BLOCKSTOREHEAD_SIZE, %rdx
	xor	%rcx, %rcx
	call	_BlockStore_write
	jmp	2f

1:
	# Backing file DOES exist. Read the head directly into the alloc'd space
	mov	FILE(%rbp), %rdi
	mov	$O_RDWR, %rsi
	mov	$SYS_OPEN, %rax
	syscall

	mov	THIS(%rbp), %rdi
	mov	%rax, BlockStore.fd(%rdi)
	mov	%rdi, %rsi
	mov	$BLOCKSTOREMETA_SIZE, %rdx
	xor	%rcx, %rcx
	call	_BlockStore_read

2:
	mov	%rdi, %rax
	mov	%rbp, %rsp
	pop	%rbp
	ret

# @public	BlockStore_read
# @description	Return the contents of the specified block
# @param	%rdi	BlockStore
# @param	%rsi	Index of the block
# @param	%rdx	Buffer
# @return	%rax	The number of characters read on success or an error code
.equ	INDX, -8
.equ	BUFF, -16
.type	BlockStore_read, @function
BlockStore_read:
	push	%rbp
	mov	%rsp, %rbp

	sub	$16, %rsp
	mov	%rsi, INDX(%rbp)
	mov	%rdx, BUFF(%rbp)

	# Triangulate offset of block
	mov	%rsi, %rax
	mov	BlockStore.sz(%rdi), %ecx
	bsr	%rcx, %rcx			# Bit scan reverse gets the number of left shifts
	shl	%cl, %rax
	add	$BLOCKSTOREMETA_SIZE, %rax

	mov	%rdx, %rsi
	mov	BlockStore.sz(%rdi), %edx
	mov	%rax, %rcx
	call	_BlockStore_read

	mov	INDX(%rbp), %rsi
	mov	BUFF(%rbp), %rdx
	mov	%rdx, %rax
	mov	%rbp, %rsp
	pop	%rbp
	ret

# @public	BlockStore_write
# @description	Write the specified contents to the specified block
# @param	%rdi	BlockStore
# @param	%rsi	Index of the block to write to
# @param	%rdx	Contents to write
# @return	void
.type	BlockStore_write, @function
BlockStore_write:
	ret

# @public	BlockStore_place
# @description	Return a new index and store the specified contents at this index
# @param	%rdi	BlockStore
# @param	%rsi	Buffer to place
# @return	%rax	The index of the new block
.equ	THIS, -8
.equ	DATA, -16
.equ	OFFS, -24
.equ	FREE, -32
.type	BlockStore_place, @function
BlockStore_place:
	push	%rbp
	mov	%rsp, %rbp

	# Locals
	sub	$32, %rsp
	mov	%rdi, THIS(%rbp)
	mov	%rsi, DATA(%rbp)

	# Calculate the offset of the next free block
	mov	BlockStore.fr(%rdi), %eax
	mull	BlockStore.sz(%rdi)
	add	$BLOCKSTOREMETA_SIZE, %rax
	mov	%rax, OFFS(%rbp)

	# Create a temp buffer on the stack block header/contents
	# TODO: See if this can't be coopted with the stack assignment in "locals"
	mov	BlockStore.sz(%rdi), %eax
	sub	%rax, %rsp

	# Try to read the new free pointer of the free block onto the stack buffer
	mov	%rsp, %rsi			# Stack buffer (to read to)
	mov	$1<<2, %rdx			# Number of bytes (to read) ... 4
	mov	OFFS(%rbp), %rcx		# Offset (to read from)
	call	_BlockStore_read

	# If bytes were read it means the block has a free and that this will soon be the new free
	test	%rax, %rax
	cmovnz	(%rsp), %eax
	jnz	1f

	# Otherwise we will just increment the existing free
	mov	BlockStore.fr(%rdi), %eax
	inc	%rax
	mov	%rax, FREE(%rbp)

1:
	# MOVSB
	mov	BlockStore.sz(%rdi), %ecx
	sub	$BLOCKSTOREHEAD_SIZE, %rcx		# Count
	mov	DATA(%rbp), %rsi			# Source
	lea	BLOCKSTOREHEAD_SIZE(%rsp), %rdi		# Destination

	mov	%ecx, BlockStore.sz(%rsp)		# Size (temp buffer)
	movl	$NULL, BlockStore.fr(%rsp)		# Free (temp buffer)
	rep	movsb					# Data (temp buffer)

	# FINALLY ready to write data to the file
	mov	THIS(%rbp), %rdi
	mov	%rsp, %rsi
	mov	BlockStore.sz(%rdi), %edx
	mov	BlockStore.fr(%rdi), %ecx
	call	_BlockStore_write

	# Update free pointer and length
	mov	FREE(%rbp), %rax
	mov	%eax, BlockStore.fr(%rdi)
	incl	BlockStore.ln(%rdi)

	# Update the block meta
	mov	%rdi, %rsi
	mov	$BLOCKSTOREMETA_SIZE, %rdx
	xor	%rcx, %rcx
	call	_BlockStore_write

	mov	INDX(%rbp), %rax

	mov	%rbp, %rsp
	pop	%rbp
	ret

# @public	BlockStore_free
# @description	Free the block at the specified index
# @param	%rdi	Index of the block to free
# @return	void
.type	BlockStore_free, @function
BlockStore_free:
	ret

# @private	_BlockStore_write
# @description	Writes the specified contents to the BlockStore at the specified offset
# @param	%rdi	BlockStore
# @param	%rsi	Buffer to write
# @param	%rdx	Number of bytes
# @param	%rcx	Offset
# @return	%rax	The number of bytes written on success, an error code on failure
_BlockStore_write:
	push	%rdi
	mov	BlockStore.fd(%rdi), %edi
	mov	%rcx, %r10
	mov	$SYS_PWRITE64, %rax
	syscall
	pop	%rdi
	ret

# @private	_BlockStore_read
# @description	Reads the specified contents of the BlockStore into the specified memory location
# @param	%rdi	BlockStore
# @param	%rsi	Buffer to read to
# @param	%rdx	Number of bytes
# @param	%rcx	Offset
# @return	%rax	The number of bytes read on success, an error code on failure
_BlockStore_read:
	push	%rdi
	mov	BlockStore.fd(%rdi), %edi
	mov	%rcx, %r10
	mov	$SYS_PREAD64, %rax
	syscall
	pop	%rdi
	ret
